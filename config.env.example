# Copy this file to config.env and fill real values.

# Required
TINVEST_TOKEN=""
TINVEST_ACCOUNT_ID=""

# Optional connection settings
TINVEST_ENDPOINT=""
TINVEST_SANDBOX="false"
TINVEST_CA_CERT_FILE=""
TINVEST_INSECURE_SKIP_VERIFY="true"

# Optional app settings
TINVEST_APP_NAME="tinvest-pnl-report"
TINVEST_TIMEOUT="60s"
TINVEST_DB_PATH="./pnl.sqlite"
TINVEST_HTTP_ADDR=":8080"
TINVEST_SYNC_ON_START="false"

# Forecasts analytics
FORECAST_PROVIDER_PRIMARY="finnhub"
FORECAST_PROVIDER_FALLBACK=""
FORECAST_ENABLE_FALLBACK="false"
FORECAST_HORIZONS="1M,3M,6M,12M"
FORECAST_SYNC_INTERVAL="24h"
FINNHUB_API_KEY=""

# Optional Go override
GO_BIN="/home/shmel/go/go1.24.0/bin/go"
